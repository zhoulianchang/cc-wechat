{
  "name": "cc-wechat",
  "version": "0.1.0",
  "description": "Bridge personal WeChat to local Claude Code via ilink bot API",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node --enable-source-maps dist/setup.js",
    "start": "node --enable-source-maps dist/index.js",
    "daemon": "node --enable-source-maps dist/daemon/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.100",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
